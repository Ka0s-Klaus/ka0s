            "sh",
            "-c",
            "if [ ! -f /web-data/conf/production/config-itop.php ]; then\n  echo \"Initializing iTop files...\"\n  cp -r /var/www/html/. /web-data/\nelse\n  echo \"Config file exists, preserving configuration...\"\n  # Only sync code, preserve config\n  cp -r /var/www/html/application /web-data/\n  cp -r /var/www/html/core /web-data/\n  cp -r /var/www/html/css /web-data/\n  cp -r /var/www/html/data /web-data/\n  cp -r /var/www/html/datamodels /web-data/\n  cp -r /var/www/html/dictionaries /web-data/\n  cp -r /var/www/html/env-production /web-data/\n  cp -r /var/www/html/images /web-data/\n  cp -r /var/www/html/js /web-data/\n  cp -r /var/www/html/lib /web-data/\n  cp -r /var/www/html/pages /web-data/\n  cp -r /var/www/html/portal /web-data/\n  cp -r /var/www/html/setup /web-data/\n  cp -r /var/www/html/sources /web-data/\n  cp -r /var/www/html/webservices /web-data/\n  cp -r /var/www/html/index.php /web-data/\nfi && \\\nif [ -f /web-data/conf/production/config-itop.php ]; then \\\n   echo \"Setting correct app_root_url in config-itop.php...\" && \\\n   chmod 660 /web-data/conf/production/config-itop.php && \\\n   if grep -q \"'app_root_url' =>\" /web-data/conf/production/config-itop.php; then\n     sed -i \"s|'app_root_url' => .*|'app_root_url' => 'https://itsm.ka0s.io/',|\" /web-data/conf/production/config-itop.php;\n   fi\nfi && \\\necho \"Applying custom branding...\" && \\\nmkdir -p /web-data/images && \\\nif [ -f /branding/zabbix_logo.png ]; then \\\n   cp /branding/zabbix_logo.png /web-data/images/custom_logo.png; \\\n   cp /branding/zabbix_logo_compact.png /web-data/images/custom_logo_compact.png; \\\n   find /web-data/images -name \"itop-logo*.png\" -exec cp /branding/zabbix_logo.png {} \\; ; \\\n   find /web-data -name \"*.css\" -type f -exec sh -c 'printf \"\\n.ibo-navigation-menu--logo img, .ibo-header__logo img, #login-logo img { opacity: 0; }\\n.ibo-navigation-menu--logo, .ibo-header__logo, #login-logo a { background-image: url(../images/custom_logo.png) !important; background-repeat: no-repeat !important; background-size: 250px !important; background-position: left center !important; width: 220px !important; height: 56px !important; display: block; }\\n.ibo-is-collapsed .ibo-navigation-menu--logo, .ibo-navigation-menu--minified .ibo-navigation-menu--logo { background-image: url(../images/custom_logo_compact.png) !important; background-size: 30px auto !important; background-position: center center !important; width: 30px !important; }\\n\" >> \"$1\"' -- {} \\; || true; \\\n fi && \\\nchmod -R 775 /web-data/conf && \\\nchmod 444 /web-data/conf/production/config-itop.php && \\\nchown -R 33:33 /web-data\n"
