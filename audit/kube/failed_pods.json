            "if [ ! -f /web-data/conf/production/config-itop.php ]; then\n  echo \"Initializing iTop files...\"\n  cp -r /var/www/html/. /web-data/\nelse\n  echo \"Config file exists, preserving configuration...\"\n  # Only sync code, preserve config\n  cp -r /var/www/html/application /web-data/\n  cp -r /var/www/html/core /web-data/\n  cp -r /var/www/html/css /web-data/\n  cp -r /var/www/html/data /web-data/\n  cp -r /var/www/html/datamodels /web-data/\n  cp -r /var/www/html/dictionaries /web-data/\n  cp -r /var/www/html/env-production /web-data/\n  cp -r /var/www/html/images /web-data/\n  cp -r /var/www/html/js /web-data/\n  cp -r /var/www/html/lib /web-data/\n  cp -r /var/www/html/pages /web-data/\n  cp -r /var/www/html/portal /web-data/\n  cp -r /var/www/html/setup /web-data/\n  cp -r /var/www/html/sources /web-data/\n  cp -r /var/www/html/webservices /web-data/\n  cp -r /var/www/html/index.php /web-data/\nfi && \\\nif [ -f /web-data/conf/production/config-itop.php ]; then \\\n   echo \"Setting correct app_root_url in config-itop.php...\" && \\\n   chmod 660 /web-data/conf/production/config-itop.php && \\\n   if grep -q \"'app_root_url' =>\" /web-data/conf/production/config-itop.php; then\n     sed -i \"s|'app_root_url' => .*|'app_root_url' => 'https://itsm.ka0s.io/',|\" /web-data/conf/production/config-itop.php;\n   fi\nfi && \\\necho \"Applying custom branding...\" && \\\nmkdir -p /web-data/images && \\\nif [ -f /branding/favicon.png ]; then\n   find /web-data -type f \\( -name \"favicon.ico\" -o -name \"apple-touch-icon*.png\" -o -name \"ms-tile*.png\" -o -name \"touch-icon*.png\" \\) -exec cp /branding/favicon.png {} \\; 2>/dev/null || true;\n fi && \\\n if [ -f /branding/custom_logo.png ]; then \\\n   cp /branding/custom_logo.png /web-data/images/custom_logo.png; \\\n   # Force copy custom_logo_compact.png\n   if [ -f /branding/custom_logo_compact.png ]; then\n     cp /branding/custom_logo_compact.png /web-data/images/custom_logo_compact.png;\n   fi\n   # Also replace the actual file itop-logo-square.png if it exists, to be double sure\n   find /web-data/images -name \"itop-logo-square.png\" -exec cp /branding/custom_logo_compact.png {} \\; || true;\n   # Replace ALL png logos related to iTop\n   find /web-data/images -type f \\( -iname '*itop*.png' -o -iname '*logo*.png' \\) -exec cp /branding/custom_logo.png {} \\; ; \\\n   find /web-data -name \"*.css\" -type f -exec sh -c 'printf \"\\n.ibo-navigation-menu--logo img, .ibo-header__logo img, #login-logo img { opacity: 0; }\\n.ibo-navigation-menu--logo, .ibo-header__logo, #login-logo a { background-image: url(../images/custom_logo.png) !important; background-repeat: no-repeat !important; background-size: 250px !important; background-position: left center !important; width: 220px !important; height: 56px !important; display: block; }\\n.ibo-is-collapsed .ibo-navigation-menu--logo, .ibo-navigation-menu--minified .ibo-navigation-menu--logo { background-image: url(../images/custom_logo_compact.png) !important; background-size: contain !important; background-position: center center !important; width: 30px !important; height: 30px !important; display: block; margin-top: 10px; }\\n\" >> \"$1\"' -- {} \\; || true; \\\n   # Inject custom text for login page and footer\n    # Use find with grep first to locate files containing the string to avoid unnecessary sed executions\n    grep -l \"'UI:Login:Welcome' => 'Welcome to iTop!',\" -r /web-data | xargs sed -i \"s|'UI:Login:Welcome' => 'Welcome to iTop!',|'UI:Login:Welcome' => 'Welcome to Ka0s!',|g\" || true\n    grep -l \"'UI:Button:Login' => 'Enter iTop',\" -r /web-data | xargs sed -i \"s|'UI:Button:Login' => 'Enter iTop',|'UI:Button:Login' => 'Enter to Ka0s ',|g\" || true\n    grep -l \"'UI:Footer:PoweredBy' => 'iTop Powered by Combodo',\" -r /web-data | xargs sed -i \"s|'UI:Footer:PoweredBy' => 'iTop Powered by Combodo',|'UI:Footer:PoweredBy' => 'Ka0s Powered by iTop',|g\" || true\n  fi && \\\nchmod -R 775 /web-data/conf && \