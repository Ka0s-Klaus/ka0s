        {
          "command": [
            "sh",
            "-c",
            "set -e\nmkdir -p /work\n# Copy original files to work directory, ignoring errors for special files/permissions\ncp -a /usr/share/zabbix/. /work/ 2>/dev/null || true\n\nif [ -f /branding/zabbix_logo.png ]; then\n  mkdir -p /work/ui/assets/img /work/assets/img\n  # Replace ALL png logos related to Zabbix\n  find /work -type f \\( -iname '*zabbix*.png' -o -iname '*logo*.png' \\) -exec cp /branding/zabbix_logo.png {} \\; 2>/dev/null || true\nfi\nif [ -f /branding/zabbix_logo_compact.png ]; then\n  mkdir -p /work/ui/assets/img /work/assets/img\n  cp /branding/zabbix_logo_compact.png /work/ui/assets/img/zabbix_logo_compact.png 2>/dev/null || true\n  cp /branding/zabbix_logo_compact.png /work/assets/img/zabbix_logo_compact.png 2>/dev/null || true\nfi\nif [ -f /branding/favicon.png ]; then\n  # Replace favicon and mobile icons\n  find /work -type f \\( -name \"favicon.ico\" -o -name \"apple-touch-icon*.png\" -o -name \"ms-tile*.png\" -o -name \"touch-icon*.png\" \\) -exec cp /branding/favicon.png {} \\; 2>/dev/null || true\nfi\nif [ -f /branding/zabbix_logo.svg ]; then\n  mkdir -p /work/ui/assets/img /work/assets/img\n   # Replace ALL svg logos related to Zabbix\n  find /work -type f \\( -iname '*zabbix*.svg' -o -iname '*logo*.svg' \\) -exec cp /branding/zabbix_logo.svg {} \\; 2>/dev/null || true\nfi\ngrep -RIl \"zabbix-logo-sidebar\" /work 2>/dev/null | while IFS= read -r f; do\n  case \"$f\" in\n    *.css) printf '\\n.zabbix-logo-sidebar{background-image:url(../img/zabbix_logo.png) !important;background-repeat:no-repeat !important;background-size:250px !important;background-position:left center !important;background-color:transparent !important;width:220px !important;height:56px !important;}\\n.sidebar-compact .zabbix-logo-sidebar,.is-compact .zabbix-logo-sidebar,.sidebar-collapsed .zabbix-logo-sidebar,.zabbix-logo-sidebar-compact,.zabbix-logo-sidebar-mini{background-image:url(../img/zabbix_logo_compact.png) !important;background-repeat:no-repeat !important;background-size:130px auto !important;background-position:center center !important;background-color:transparent !important;width:30px !important;height:56px !important;}\\n.signin-logo{background-image:url(../img/zabbix_logo.png) !important;background-repeat:no-repeat !important;background-size:contain !important;background-position:center center !important;width:100% !important;height:60px !important;margin-bottom:20px !important;}\\n' >> \"$f\" ;;\n  esac\ndone\n"
